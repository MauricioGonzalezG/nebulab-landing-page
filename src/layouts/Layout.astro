---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Nebulab 3D — Si lo puedes imaginar, lo podemos crear',
  description = 'Empresa de impresión 3D en Manizales y Madrid, Cundinamarca. Regalos personalizados, corporativos, litofanías, decoración para restaurantes y más.',
} = Astro.props;
---

<!doctype html>
<html lang="es" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#8446c2" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.cdnfonts.com/css/makoto" rel="stylesheet" />

  <!-- Dark mode init (runs before render to prevent flash) -->
  <script is:inline>
    (function () {
      const stored = localStorage.getItem('neb-theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = stored || (prefersDark ? 'dark' : 'light');
      document.documentElement.classList.toggle('dark', theme === 'dark');
    })();
  </script>
</head>

<body class="
  bg-neb-cream dark:bg-neb-black
  text-neb-ink dark:text-white
  font-sans antialiased
  transition-colors duration-300
  overflow-x-hidden
">

  <!-- ── Global noise grain overlay ── -->
  <div aria-hidden="true" class="pointer-events-none fixed inset-0 z-[999] opacity-[0.025] dark:opacity-[0.04]"
       style="background-image:url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22300%22 height=%22300%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22300%22 height=%22300%22 filter=%22url(%23n)%22/%3E%3C/svg%3E');"></div>

  <!-- ── CRT scanline (dark only) ── -->
  <div aria-hidden="true"
       class="pointer-events-none fixed inset-0 z-[998] hidden dark:block overflow-hidden"
       style="background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px);">
  </div>

  <slot />

  <!-- ── WhatsApp FAB ── -->
  <a href="https://wa.me/573232218586?text=Hola%20Nebulab%203D%2C%20quiero%20cotizar%20un%20proyecto"
     target="_blank" rel="noopener noreferrer"
     aria-label="Chatear por WhatsApp"
     class="fixed bottom-6 right-6 z-50 w-14 h-14 rounded-full flex items-center justify-center shadow-lg
            bg-[#25D366] hover:bg-[#1ebe5d]
            shadow-[0_4px_20px_rgba(37,211,102,0.45)]
            hover:scale-110 transition-all duration-200">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="white" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <!-- ── Global scripts ── -->
  <script>
    // ── Theme toggle ──────────────────────────────────
    function applyTheme(t: string) {
      document.documentElement.classList.toggle('dark', t === 'dark');
      localStorage.setItem('neb-theme', t);
      document.querySelectorAll('[data-theme-icon]').forEach(el => {
        (el as HTMLElement).dataset.theme = t;
      });
    }
    window.toggleTheme = function () {
      const isDark = document.documentElement.classList.contains('dark');
      applyTheme(isDark ? 'light' : 'dark');
    };

    // ── Scroll reveal ─────────────────────────────────
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          revealObserver.unobserve(e.target);
        }
      });
    }, { threshold: 0.12 });
    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

    // ── Navbar scroll glass ───────────────────────────
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      navbar?.classList.toggle('scrolled', window.scrollY > 40);
    }, { passive: true });

    // ── Mobile menu ───────────────────────────────────
    const toggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => {
      const open = mobileMenu?.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(open));
    });
    window.closeMobileMenu = function () {
      mobileMenu?.classList.remove('open');
    };

    // ── Contact form → WhatsApp ───────────────────────
    window.handleFormSubmit = function (e: Event) {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const name    = (form.elements.namedItem('name')    as HTMLInputElement)?.value  || '';
      const phone   = (form.elements.namedItem('phone')   as HTMLInputElement)?.value  || '';
      const message = (form.elements.namedItem('message') as HTMLTextAreaElement)?.value || '';
      const text = encodeURIComponent(
        `Hola Nebulab 3D, soy ${name}${phone ? ' (' + phone + ')' : ''}.\n\n${message}`
      );
      window.open(`https://wa.me/573232218586?text=${text}`, '_blank', 'noopener');
    };
  </script>

  <style is:global>
    /* ── Makoto display font ── */
    .font-makoto { font-family: 'Makoto', 'Montserrat', sans-serif; }

    /* ── Gradient text ── */
    .text-gradient {
      background: linear-gradient(135deg, #8446c2 0%, #5564ef 50%, #027ac3 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .dark .text-gradient {
      background: linear-gradient(135deg, #c084fc 0%, #818cf8 50%, #38bdf8 100%);
      -webkit-background-clip: text;
      background-clip: text;
    }

    /* ── Divider ── */
    .divider {
      width: 60px; height: 4px; border-radius: 2px;
      background: linear-gradient(90deg, #8446c2, #5564ef);
    }

    /* ── Section badge ── */
    .badge {
      display: inline-block;
      padding: 3px 12px;
      border-radius: 2px;
      border: 1px dashed rgba(132,70,194,0.6);
      font-size: 0.65rem;
      font-weight: 700;
      font-family: 'Space Mono', monospace;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #8446c2;
    }
    .dark .badge {
      border-color: rgba(192,132,252,0.5);
      color: #c084fc;
    }

    /* ── Reveal animation ── */
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.65s ease, transform 0.65s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── Navbar scroll state ── */
    #navbar { transition: background 0.3s, box-shadow 0.3s; }
    #navbar.scrolled {
      background: rgba(249,246,255,0.92);
      box-shadow: 0 1px 0 rgba(132,70,194,0.12);
      backdrop-filter: blur(20px);
    }
    .dark #navbar.scrolled {
      background: rgba(14,14,14,0.88);
      box-shadow: 0 1px 0 rgba(132,70,194,0.15);
    }

    /* ── Mobile menu ── */
    #mobile-menu { max-height: 0; overflow: hidden; transition: max-height 0.35s ease; }
    #mobile-menu.open { max-height: 440px; }

    /* ── Reduced motion ── */
    @media (prefers-reduced-motion: reduce) {
      *, .reveal { transition: none !important; animation: none !important; }
    }

    /* ── Retro pixel corner ── */
    .pixel-corner {
      clip-path: polygon(8px 0%, 100% 0%, 100% calc(100% - 8px), calc(100% - 8px) 100%, 0% 100%, 0% 8px);
    }

    /* ── Gallery ── */
    .gallery-tab.active {
      background: #8446c2;
      color: white;
      border-color: #8446c2;
    }
    .dark .gallery-tab.active {
      background: #8446c2;
      border-color: #c084fc;
    }
    .gallery-item { display: none; }
    .gallery-item.visible { display: block; }

    /* ── Image hover retro glow ── */
    .img-retro {
      transition: transform 0.3s ease, filter 0.3s ease, box-shadow 0.3s ease;
    }
    .img-retro:hover {
      transform: scale(1.03);
      filter: brightness(1.05) saturate(1.1);
      box-shadow: 0 0 24px rgba(132,70,194,0.4), 0 0 48px rgba(85,100,239,0.2);
    }

    /* ── Button primary ── */
    .btn-primary {
      background: linear-gradient(135deg, #8446c2, #5564ef);
      transition: opacity 0.2s, transform 0.2s, box-shadow 0.2s;
    }
    .btn-primary:hover {
      opacity: 0.88;
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(132,70,194,0.4);
    }

    /* ── Button outline ── */
    .btn-outline {
      border: 2px solid #8446c2;
      color: #8446c2;
      transition: background 0.2s, color 0.2s, transform 0.2s;
    }
    .btn-outline:hover {
      background: rgba(132,70,194,0.12);
      transform: translateY(-2px);
    }
    .dark .btn-outline { color: white; border-color: rgba(192,132,252,0.7); }
    .dark .btn-outline:hover { background: rgba(192,132,252,0.12); }

    /* ── Service card ── */
    .card-service {
      border: 1px solid rgba(132,70,194,0.18);
      background: rgba(249,246,255,0.6);
      backdrop-filter: blur(8px);
      transition: border-color 0.25s, transform 0.25s, background 0.25s, box-shadow 0.25s;
    }
    .card-service:hover {
      border-color: #8446c2;
      background: rgba(132,70,194,0.06);
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(132,70,194,0.15);
    }
    .dark .card-service {
      background: rgba(255,255,255,0.03);
      border-color: rgba(132,70,194,0.2);
    }
    .dark .card-service:hover {
      background: rgba(132,70,194,0.1);
      box-shadow: 0 12px 40px rgba(132,70,194,0.25);
    }

    /* ── Value card ── */
    .card-value {
      background: rgba(249,246,255,0.7);
      border: 1px solid rgba(85,100,239,0.18);
      backdrop-filter: blur(8px);
      transition: transform 0.3s, box-shadow 0.3s;
    }
    .card-value:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(85,100,239,0.15); }
    .dark .card-value {
      background: rgba(255,255,255,0.03);
      border-color: rgba(85,100,239,0.2);
    }

    /* ── Glow blobs ── */
    .glow-purple { filter: blur(80px); background: rgba(132,70,194,0.35); }
    .glow-blue   { filter: blur(80px); background: rgba(85,100,239,0.3); }
    .dark .glow-purple { background: rgba(132,70,194,0.45); }
    .dark .glow-blue   { background: rgba(85,100,239,0.4); }

    /* ── Star particles ── */
    .star {
      position: absolute;
      width: 2px; height: 2px;
      border-radius: 50%;
      background: white;
      opacity: 0;
      animation: twinkle var(--dur, 4s) ease-in-out var(--delay, 0s) infinite;
    }
    @keyframes twinkle {
      0%,100% { opacity: 0; }
      50%      { opacity: var(--max-op, 0.7); }
    }

    /* ── Scrollbar ── */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #8446c2; border-radius: 3px; }
  </style>
</body>
</html>
