---
---
<nav id="navbar" class="fixed top-0 inset-x-0 z-50 py-3 px-6 md:px-12 flex items-center justify-between">

  <!-- ── Logo ── -->
  <a href="#" class="flex items-center group" aria-label="Nebulab 3D inicio">
    <!-- Light mode logo -->
    <img
      src="/images/logo/logo-principal-light.png"
      alt="Nebulab 3D"
      width="48" height="48"
      class="w-32 h-12 object-contain opacity-90 group-hover:opacity-100 group-hover:drop-shadow-[0_0_8px_rgba(132,70,194,0.6)] transition-all duration-300 block dark:hidden"
    />
    <!-- Dark mode logo -->
    <img
      src="/images/logo/logo-principal-dark.png"
      alt="Nebulab 3D"
      width="48" height="48"
      class="w-32 h-12 object-contain opacity-90 group-hover:opacity-100 group-hover:drop-shadow-[0_0_8px_rgba(132,70,194,0.6)] transition-all duration-300 hidden dark:block"
    />
  </a>

  <!-- ── Desktop links ── -->
  <ul class="hidden md:flex items-center gap-8">
    {[
      ['#servicios','Servicios'],
      ['#galeria',  'Galería'],
      ['#nosotros', 'Nosotros'],
      ['#contacto', 'Contacto'],
    ].map(([href, label]) => (
      <li>
        <a href={href}
           class="text-sm font-semibold font-mono text-neb-ink/70 dark:text-white/75
                  hover:text-neb-purple dark:hover:text-neb-purple
                  transition-colors duration-200 tracking-wide relative
                  after:absolute after:-bottom-0.5 after:left-0 after:w-0 after:h-px
                  after:bg-neb-purple after:transition-all hover:after:w-full">
          {label}
        </a>
      </li>
    ))}
  </ul>

  <!-- ── Right cluster ── -->
  <div class="flex items-center gap-3">
    <!-- Theme toggle -->
    <button
      onclick="window.toggleTheme()"
      data-theme-icon
      aria-label="Cambiar tema"
      class="w-9 h-9 rounded-lg border border-neb-purple/30 dark:border-neb-purple/40
             flex items-center justify-center
             hover:bg-neb-purple/10 transition-colors duration-200 cursor-pointer">
      <!-- Sun icon (visible in dark mode) -->
      <svg class="hidden dark:block" width="17" height="17" viewBox="0 0 24 24" fill="none"
           stroke="#c084fc" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <!-- Moon icon (visible in light mode) -->
      <svg class="block dark:hidden" width="17" height="17" viewBox="0 0 24 24" fill="none"
           stroke="#8446c2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
      </svg>
    </button>

    <!-- CTA desktop -->
    <a href="https://wa.me/573232218586?text=Hola%20Nebulab%203D%2C%20quiero%20cotizar%20un%20proyecto"
       target="_blank" rel="noopener"
       class="hidden md:inline-flex btn-primary text-white text-xs font-bold font-mono
              px-4 py-2.5 rounded-sm tracking-widest uppercase cursor-pointer pixel-corner">
      COTIZAR
    </a>

    <!-- Hamburger -->
    <button id="menu-toggle" aria-label="Abrir menú" aria-expanded="false"
            class="md:hidden flex flex-col gap-1.5 p-1 cursor-pointer">
      <span class="block w-6 h-0.5 bg-neb-ink dark:bg-white transition-all duration-200" id="bar1"></span>
      <span class="block w-6 h-0.5 bg-neb-ink dark:bg-white transition-all duration-200" id="bar2"></span>
      <span class="block w-6 h-0.5 bg-neb-ink dark:bg-white transition-all duration-200" id="bar3"></span>
    </button>
  </div>
</nav>

<!-- ── Mobile menu ── -->
<div id="mobile-menu"
     class="fixed top-[60px] inset-x-0 z-40
            bg-neb-cream/96 dark:bg-neb-black/96
            backdrop-blur-xl border-b border-neb-purple/15">
  <ul class="flex flex-col gap-1 px-6 py-4 text-sm font-semibold font-mono">
    {[
      ['#servicios','Servicios'],
      ['#galeria',  'Galería'],
      ['#nosotros', 'Nosotros'],
      ['#contacto', 'Contacto'],
    ].map(([href, label]) => (
      <li>
        <a href={href} onclick="window.closeMobileMenu()"
           class="block py-2.5 tracking-wide text-neb-ink/80 dark:text-white/80
                  hover:text-neb-purple dark:hover:text-neb-purple transition-colors border-b border-neb-purple/10">
          &gt; {label}
        </a>
      </li>
    ))}
    <li class="pt-3">
      <a href="https://wa.me/573232218586?text=Hola%20Nebulab%203D%2C%20quiero%20cotizar%20un%20proyecto"
         target="_blank" rel="noopener"
         class="btn-primary inline-block text-white text-xs font-bold px-5 py-3 rounded-sm tracking-widest uppercase pixel-corner">
        COTIZAR AHORA
      </a>
    </li>
  </ul>
</div>
