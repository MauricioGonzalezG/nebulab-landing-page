---
---
<section id="contacto" class="py-24 px-6 relative overflow-hidden">

  <!-- Glow -->
  <div aria-hidden="true"
       class="glow-purple absolute bottom-0 left-1/2 -translate-x-1/2 w-96 h-64 rounded-full opacity-15 dark:opacity-20 pointer-events-none"></div>

  <div class="max-w-5xl mx-auto relative">

    <div class="text-center mb-16 reveal">
      <span class="badge mb-4 inline-block">Hablemos</span>
      <h2 class="font-makoto text-4xl md:text-5xl font-black mb-4 text-neb-ink dark:text-white">
        CONTÁCTANOS
      </h2>
      <div class="divider mx-auto mt-4"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-10 items-start">

      <!-- ── Contact info ── -->
      <div class="flex flex-col gap-4 reveal">

        <a href="https://wa.me/573232218586"
           target="_blank" rel="noopener"
           class="flex items-center gap-4 p-5 rounded-sm border border-white/10 dark:border-white/8
                  bg-neb-ink/[0.03] dark:bg-white/[0.03]
                  hover:border-neb-purple/40 transition-colors group pixel-corner">
          <div class="w-11 h-11 rounded-sm bg-green-500/15 border border-green-500/25 flex items-center justify-center shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="#25D366" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <div>
            <p class="font-mono text-[9px] text-neb-ink/35 dark:text-white/30 font-bold uppercase tracking-[0.2em] mb-0.5">WHATSAPP</p>
            <p class="font-bold text-neb-ink dark:text-white group-hover:text-neb-purple transition-colors">+57 323 221 8586</p>
          </div>
        </a>

        <a href="https://www.instagram.com/nebulab3d/"
           target="_blank" rel="noopener"
           class="flex items-center gap-4 p-5 rounded-sm border border-white/10 dark:border-white/8
                  bg-neb-ink/[0.03] dark:bg-white/[0.03]
                  hover:border-neb-purple/40 transition-colors group pixel-corner">
          <div class="w-11 h-11 rounded-sm bg-neb-mauve/15 border border-neb-mauve/25 flex items-center justify-center shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                 stroke="#a85b8a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </div>
          <div>
            <p class="font-mono text-[9px] text-neb-ink/35 dark:text-white/30 font-bold uppercase tracking-[0.2em] mb-0.5">INSTAGRAM</p>
            <p class="font-bold text-neb-ink dark:text-white group-hover:text-neb-purple transition-colors">@nebulab3d</p>
          </div>
        </a>

        <div class="flex items-center gap-4 p-5 rounded-sm border border-white/10 dark:border-white/8
                    bg-neb-ink/[0.03] dark:bg-white/[0.03] pixel-corner">
          <div class="w-11 h-11 rounded-sm bg-neb-purple/15 border border-neb-purple/25 flex items-center justify-center shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                 stroke="#8446c2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div>
            <p class="font-mono text-[9px] text-neb-ink/35 dark:text-white/30 font-bold uppercase tracking-[0.2em] mb-0.5">UBICACIÓN</p>
            <p class="font-bold text-neb-ink dark:text-white">Manizales · Madrid, Cundinamarca</p>
          </div>
        </div>

        <!-- Featured product image -->
        <div class="relative rounded-sm overflow-hidden mt-2 hidden md:block">
          <img
            src="/images/B2B/b2b-11.jpg"
            alt="Producto Nebulab 3D"
            loading="lazy"
            class="w-full h-40 object-cover img-retro"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-neb-ink/50 to-transparent"></div>
          <div class="absolute top-2 left-2 w-3 h-3 border-t-2 border-l-2 border-neb-purple/80"></div>
          <div class="absolute bottom-2 right-2 w-3 h-3 border-b-2 border-r-2 border-neb-blue/80"></div>
        </div>
      </div>

      <!-- ── Form ── -->
      <form class="flex flex-col gap-4 reveal" onsubmit="window.handleFormSubmit(event)">
        <!-- Terminal header -->
        <div class="border border-neb-purple/20 dark:border-neb-purple/25 rounded-sm px-4 py-2.5 flex items-center gap-2 mb-1">
          <div class="w-2 h-2 rounded-full bg-red-400/60"></div>
          <div class="w-2 h-2 rounded-full bg-yellow-400/60"></div>
          <div class="w-2 h-2 rounded-full bg-green-400/60"></div>
          <span class="font-mono text-[9px] tracking-[0.2em] uppercase text-neb-ink/30 dark:text-white/25 ml-2">
            nebulab ~ contacto
          </span>
        </div>

        <div>
          <label for="name" class="block font-mono text-[10px] font-bold text-neb-purple/80 uppercase tracking-[0.2em] mb-1.5">
            &gt; nombre
          </label>
          <input id="name" name="name" type="text" required autocomplete="name"
                 placeholder="Tu nombre completo"
                 class="w-full bg-neb-ink/[0.04] dark:bg-white/[0.04] border border-neb-purple/20 dark:border-neb-purple/20
                        rounded-sm px-4 py-3 text-sm text-neb-ink dark:text-white
                        placeholder-neb-ink/30 dark:placeholder-white/25
                        focus:outline-none focus:border-neb-purple transition-colors font-mono" />
        </div>

        <div>
          <label for="phone" class="block font-mono text-[10px] font-bold text-neb-purple/80 uppercase tracking-[0.2em] mb-1.5">
            &gt; whatsapp / teléfono
          </label>
          <input id="phone" name="phone" type="tel" autocomplete="tel"
                 placeholder="+57 300 000 0000"
                 class="w-full bg-neb-ink/[0.04] dark:bg-white/[0.04] border border-neb-purple/20 dark:border-neb-purple/20
                        rounded-sm px-4 py-3 text-sm text-neb-ink dark:text-white
                        placeholder-neb-ink/30 dark:placeholder-white/25
                        focus:outline-none focus:border-neb-purple transition-colors font-mono" />
        </div>

        <div>
          <label for="message" class="block font-mono text-[10px] font-bold text-neb-purple/80 uppercase tracking-[0.2em] mb-1.5">
            &gt; ¿qué quieres crear?
          </label>
          <textarea id="message" name="message" rows="4" required
                    placeholder="Cuéntanos tu idea..."
                    class="w-full bg-neb-ink/[0.04] dark:bg-white/[0.04] border border-neb-purple/20 dark:border-neb-purple/20
                           rounded-sm px-4 py-3 text-sm text-neb-ink dark:text-white
                           placeholder-neb-ink/30 dark:placeholder-white/25
                           focus:outline-none focus:border-neb-purple transition-colors font-mono
                           resize-none"></textarea>
        </div>

        <button type="submit"
                class="btn-primary text-white font-bold font-mono text-xs px-6 py-4
                       rounded-sm tracking-widest uppercase pixel-corner
                       flex items-center justify-center gap-2 cursor-pointer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="white" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          ENVIAR POR WHATSAPP
        </button>

        <p class="font-mono text-[9px] text-neb-ink/35 dark:text-white/25 tracking-wide text-center">
          El mensaje se abrirá en WhatsApp. Sin spam.
        </p>
      </form>

    </div>
  </div>
</section>
