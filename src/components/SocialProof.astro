---
const reels = [
  {
    url: 'https://www.instagram.com/reel/DVw55OpkjvV/',
    permalink: 'https://www.instagram.com/reel/DVw55OpkjvV/?utm_source=ig_embed&utm_campaign=loading',
    label: 'Regalos corporativos',
  },
  {
    url: 'https://www.instagram.com/reel/DJ23LleNYgo/',
    permalink: 'https://www.instagram.com/reel/DJ23LleNYgo/?utm_source=ig_embed&utm_campaign=loading',
    label: 'Bases QR personalizadas',
  },
  {
    url: 'https://www.instagram.com/reel/DQ5aCRHDYdP/',
    permalink: 'https://www.instagram.com/reel/DQ5aCRHDYdP/?utm_source=ig_embed&utm_campaign=loading',
    label: 'Lámparas decorativas',
  },
];
---

<section class="py-24 px-6 relative overflow-hidden">

  <!-- BG accent -->
  <div aria-hidden="true"
       class="glow-purple absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-64 rounded-full opacity-10 dark:opacity-15 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto">

    <div class="text-center mb-14 reveal">
      <span class="badge mb-4 inline-block">@nebulab3d</span>
      <h2 class="font-makoto text-4xl md:text-5xl font-black mb-4 text-neb-ink dark:text-white">
        MÍRANOS EN ACCIÓN
      </h2>
      <div class="divider mx-auto mt-4 mb-4"></div>
      <p class="font-mono text-sm text-neb-ink/50 dark:text-white/40 tracking-wide">
        Síguenos en Instagram para más contenido
      </p>
    </div>

    <!-- Reels grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {reels.map((reel, i) => (
        <div class="reveal" style={`transition-delay: ${i * 100}ms`}>
          <!-- Label -->
          <div class="flex items-center gap-2 mb-3">
            <div class="h-px flex-1 bg-neb-purple/20 dark:bg-neb-purple/25"></div>
            <span class="font-mono text-[9px] tracking-[0.2em] uppercase text-neb-purple/70 dark:text-neb-purple/60">
              {reel.label}
            </span>
            <div class="h-px flex-1 bg-neb-purple/20 dark:bg-neb-purple/25"></div>
          </div>

          <!-- Instagram embed wrapper -->
          <div class="relative overflow-hidden rounded-sm
                      border border-neb-purple/15 dark:border-neb-purple/20
                      bg-white dark:bg-[#1a1a1a]">
            <!-- Retro corner accents -->
            <div class="absolute top-1.5 left-1.5 w-3 h-3 border-t-2 border-l-2 border-neb-purple/50 z-10 pointer-events-none"></div>
            <div class="absolute bottom-1.5 right-1.5 w-3 h-3 border-b-2 border-r-2 border-neb-blue/50 z-10 pointer-events-none"></div>

            <blockquote
              class="instagram-media"
              data-instgrm-captioned
              data-instgrm-permalink={reel.permalink}
              data-instgrm-version="14"
              style="background:#FFF; border:0; border-radius:0; box-shadow:none; margin:0; max-width:100%; min-width:100%; padding:0; width:100%;">
              <div style="padding:16px;">
                <a href={reel.permalink} target="_blank" rel="noopener noreferrer"
                   style="background:#FFFFFF; line-height:0; padding:0; text-align:center; text-decoration:none; width:100%; display:block;">
                  <div style="padding: 19% 0;"></div>
                  <div style="display:block; height:50px; margin:0 auto 12px; width:50px;">
                    <svg width="50px" height="50px" viewBox="0 0 60 60" version="1.1" xmlns="http://www.w3.org/2000/svg">
                      <g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
                        <g transform="translate(-511,−20)" fill="#8446c2">
                          <g><path d="M556.869,30.41 C554.814,30.41 553.148,32.076 553.148,34.131 C553.148,36.186 554.814,37.852 556.869,37.852 C558.924,37.852 560.59,36.186 560.59,34.131 C560.59,32.076 558.924,30.41 556.869,30.41 M541,60.657 C535.114,60.657 530.342,55.887 530.342,50 C530.342,44.114 535.114,39.342 541,39.342 C546.887,39.342 551.658,44.114 551.658,50 C551.658,55.887 546.887,60.657 541,60.657"/></g>
                        </g>
                      </g>
                    </svg>
                  </div>
                  <div style="padding-top:8px;">
                    <div style="color:#8446c2;font-family:'Space Mono',monospace;font-size:12px;font-weight:700;line-height:18px;">
                      Ver en Instagram →
                    </div>
                  </div>
                  <div style="padding: 12.5% 0;"></div>
                </a>
                <p style="color:#c9c8cd;font-family:Arial,sans-serif;font-size:14px;line-height:17px;margin:8px 0 0;overflow:hidden;padding:8px 0;text-align:center;text-overflow:ellipsis;white-space:nowrap;">
                  <a href={reel.permalink} style="color:#c9c8cd;font-family:Arial,sans-serif;font-size:14px;font-style:normal;font-weight:normal;line-height:17px;text-decoration:none;" target="_blank" rel="noopener">
                    Nebulab 3D (@nebulab3d)
                  </a>
                </p>
              </div>
            </blockquote>
          </div>
        </div>
      ))}
    </div>

    <!-- Instagram CTA -->
    <div class="mt-12 text-center reveal">
      <a href="https://www.instagram.com/nebulab3d/"
         target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-3 font-mono text-sm font-bold tracking-widest uppercase
                border border-neb-purple/30 hover:border-neb-purple
                text-neb-ink/70 dark:text-white/70 hover:text-neb-purple dark:hover:text-neb-purple
                px-6 py-3 rounded-sm transition-all duration-200 pixel-corner">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
        SEGUIR EN INSTAGRAM
      </a>
    </div>

  </div>
</section>

<!-- Instagram embed script -->
<script async src="//www.instagram.com/embed.js" is:inline></script>
