---
const steps = [
  {
    num: '01',
    tag: 'TU REFERENCIA',
    title: 'Nos envías tu foto',
    desc: 'Una foto frontal clara es todo lo que necesitamos. Cuanto mejor la foto, más fiel será el resultado.',
    img: '/images/avatars/avatar-01.jpg',
    color: '#8446c2',
    glow: 'shadow-neb-purple',
    accent: 'border-neb-purple',
    bg: 'bg-neb-purple/10 dark:bg-neb-purple/20',
  },
  {
    num: '02',
    tag: 'DISEÑO DIGITAL',
    title: 'Creamos el diseño',
    desc: 'Modelamos tu figura en 3D y diseñamos la caja personalizada con tu nombre y estilo.',
    img: '/images/avatars/avatar-03.jpg',
    color: '#5564ef',
    glow: 'shadow-neb-blue',
    accent: 'border-neb-blue',
    bg: 'bg-neb-blue/10 dark:bg-neb-blue/20',
  },
  {
    num: '03',
    tag: 'IMPRESIÓN 3D',
    title: 'Imprimimos la figura',
    desc: 'Usamos resina de alta resolución para capturar cada detalle de tu cara y tu estilo personal.',
    img: '/images/avatars/avatar-02.jpg',
    color: '#027ac3',
    glow: 'shadow-neb-cyan',
    accent: 'border-neb-cyan',
    bg: 'bg-neb-cyan/10 dark:bg-neb-cyan/20',
  },
  {
    num: '04',
    tag: 'PINTADO ARTESANAL',
    title: 'Pintado a mano',
    desc: 'Cada figura se pinta manualmente con acrílicos de alta calidad para lograr un acabado único e irrepetible.',
    img: '/images/avatars/avatar-04.jpg',
    color: '#a85b8a',
    glow: 'shadow-neb-mauve',
    accent: 'border-neb-mauve',
    bg: 'bg-neb-mauve/10 dark:bg-neb-mauve/20',
  },
];
---

<section id="avatares" class="py-24 px-6 relative overflow-hidden">

  <!-- Glows -->
  <div aria-hidden="true"
       class="glow-purple absolute top-0 right-1/4 w-96 h-64 rounded-full opacity-10 dark:opacity-15 pointer-events-none"></div>
  <div aria-hidden="true"
       class="glow-blue absolute bottom-0 left-1/4 w-80 h-64 rounded-full opacity-10 dark:opacity-15 pointer-events-none"></div>

  <div class="max-w-5xl mx-auto relative">

    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <span class="badge mb-4 inline-block">Personalización extrema</span>
      <h2 class="font-makoto text-4xl md:text-5xl font-black mb-4 text-neb-ink dark:text-white">
        TU AVATAR <span class="text-gradient">PERSONALIZADO</span>
      </h2>
      <p class="text-neb-ink/60 dark:text-white/55 max-w-xl mx-auto text-base md:text-lg font-medium leading-relaxed">
        Convertimos tu foto en una figura Funko Pop única, pintada a mano y con caja personalizada.
      </p>
      <div class="divider mx-auto mt-6"></div>
    </div>

    <!-- Steps grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
      {steps.map((step, i) => (
        <div class="reveal flex flex-col gap-0" style={`transition-delay: ${i * 80}ms`}>

          <!-- Image card -->
          <div class={`relative overflow-hidden rounded-sm aspect-square ${step.glow} pixel-corner`}
               style={`box-shadow: 0 0 30px ${step.color}25`}>
            <img
              src={step.img}
              alt={step.title}
              loading="lazy"
              class="w-full h-full object-cover img-retro transition-transform duration-500 hover:scale-105"
            />
            <!-- Step number badge -->
            <div class={`absolute top-2 left-2 w-8 h-8 rounded-sm ${step.bg} border ${step.accent}
                         flex items-center justify-center backdrop-blur-sm`}>
              <span class="font-makoto text-xs font-black" style={`color: ${step.color}`}>{step.num}</span>
            </div>
            <!-- Tag -->
            <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-black/70 to-transparent px-3 py-2">
              <span class="font-mono text-[8px] tracking-[0.2em] uppercase text-white/70">{step.tag}</span>
            </div>
            <!-- Corner accents -->
            <div class={`absolute top-1 right-1 w-3 h-3 border-t-2 border-r-2 ${step.accent} opacity-60`}></div>
            <div class={`absolute bottom-1 left-1 w-3 h-3 border-b-2 border-l-2 ${step.accent} opacity-60`}></div>
          </div>

          <!-- Connector arrow (not last) -->
          {i < steps.length - 1 && (
            <div class="hidden lg:flex justify-end pr-0 -mr-3 mt-[-50%] mb-[44%] z-10 pointer-events-none">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"
                   class="opacity-30 rotate-0">
                <path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5"
                      stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          )}

          <!-- Text -->
          <div class="pt-4 px-1">
            <h3 class="font-bold font-mono text-sm text-neb-ink dark:text-white mb-1 tracking-wide">{step.title}</h3>
            <p class="text-neb-ink/55 dark:text-white/50 text-xs leading-relaxed">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center reveal">
      <a href="https://wa.me/573232218586?text=Hola%20Nebulab%203D%2C%20quiero%20un%20avatar%20personalizado"
         target="_blank" rel="noopener"
         class="btn-primary text-white font-bold font-mono text-xs px-8 py-4
                rounded-sm tracking-widest uppercase pixel-corner
                inline-flex items-center gap-2 cursor-pointer">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="white" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        QUIERO MI AVATAR
      </a>
      <p class="font-mono text-[9px] text-neb-ink/35 dark:text-white/25 tracking-wide mt-3">
        Envíos a todo Colombia · Entrega estimada: 7–10 días hábiles
      </p>
    </div>

  </div>
</section>
