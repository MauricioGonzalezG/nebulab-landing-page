---
const categories = [
  {
    id: 'llaveros',
    label: 'Llaveros',
    images: Array.from({length: 11}, (_, i) => ({
      src: `/images/llaveros/llavero-${String(i+1).padStart(2,'0')}.jpg`,
      alt: `Llavero personalizado ${i+1}`,
    })),
  },
  {
    id: 'lamparas',
    label: 'Lámparas',
    images: Array.from({length: 8}, (_, i) => ({
      src: `/images/lamparas/lampara-${String(i+1).padStart(2,'0')}.jpg`,
      alt: `Lámpara decorativa ${i+1}`,
    })),
  },
  {
    id: 'coleccionables',
    label: 'Coleccionables',
    images: Array.from({length: 4}, (_, i) => ({
      src: `/images/coleccionables/coleccionable-${String(i+1).padStart(2,'0')}.jpg`,
      alt: `Coleccionable ${i+1}`,
    })),
  },
  {
    id: 'macetas',
    label: 'Macetas',
    images: Array.from({length: 5}, (_, i) => ({
      src: `/images/macetas/maceta-${String(i+1).padStart(2,'0')}.jpg`,
      alt: `Maceta decorativa ${i+1}`,
    })),
  },
  {
    id: 'corporativos',
    label: 'Corporativos',
    images: Array.from({length: 9}, (_, i) => ({
      src: `/images/regalos-corporativos/corporativo-${String(i+1).padStart(2,'0')}.jpg`,
      alt: `Regalo corporativo ${i+1}`,
    })),
  },
  {
    id: 'temporadas',
    label: 'Temporadas',
    images: Array.from({length: 14}, (_, i) => ({
      src: `/images/temporadas/temporada-${String(i+1).padStart(2,'0')}.jpg`,
      alt: `Edición temporada ${i+1}`,
    })),
  },
];
---

<section id="galeria" class="py-24 px-6 relative overflow-hidden">

  <!-- BG accent -->
  <div aria-hidden="true" class="glow-purple absolute top-1/2 -right-24 w-96 h-96 rounded-full opacity-20 dark:opacity-30 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto">

    <div class="text-center mb-12 reveal">
      <span class="badge mb-4 inline-block">Nuestros productos</span>
      <h2 class="font-makoto text-4xl md:text-5xl font-black mb-4 text-neb-ink dark:text-white">
        GALERÍA
      </h2>
      <div class="divider mx-auto mt-4"></div>
    </div>

    <!-- Category tabs -->
    <div class="flex flex-wrap justify-center gap-2 mb-10 reveal" id="gallery-tabs">
      {categories.map((cat, i) => (
        <button
          data-tab={cat.id}
          class={`gallery-tab font-mono text-xs font-bold tracking-widest uppercase
                  px-4 py-2 rounded-sm border transition-all duration-200 cursor-pointer
                  border-neb-purple/30 text-neb-ink/60 dark:text-white/50
                  hover:border-neb-purple hover:text-neb-purple
                  ${i === 0 ? 'active' : ''}`}>
          {cat.label}
        </button>
      ))}
    </div>

    <!-- Gallery grids -->
    {categories.map((cat, catIdx) => (
      <div
        id={`tab-${cat.id}`}
        class={`gallery-grid ${catIdx === 0 ? 'visible' : ''}`}
        style={catIdx !== 0 ? 'display:none' : ''}>
        <div class="columns-2 sm:columns-3 lg:columns-4 gap-3 space-y-3">
          {cat.images.map((img, idx) => (
            <div class="break-inside-avoid reveal group relative overflow-hidden cursor-pointer rounded-sm"
                 style={`transition-delay: ${idx * 40}ms`}
                 onclick={`openLightbox('${img.src}', '${img.alt}')`}>
              <img
                src={img.src}
                alt={img.alt}
                loading="lazy"
                decoding="async"
                class="w-full object-cover img-retro"
              />
              <!-- Hover overlay -->
              <div class="absolute inset-0 bg-neb-purple/0 group-hover:bg-neb-purple/20 transition-all duration-300 flex items-center justify-center">
                <svg class="opacity-0 group-hover:opacity-100 transition-opacity duration-200 drop-shadow-lg"
                     width="28" height="28" viewBox="0 0 24 24" fill="none"
                     stroke="white" stroke-width="2" aria-hidden="true">
                  <circle cx="11" cy="11" r="8"/>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                  <line x1="11" y1="8" x2="11" y2="14"/>
                  <line x1="8" y1="11" x2="14" y2="11"/>
                </svg>
              </div>
              <!-- Retro corner tag -->
              <div class="absolute top-2 left-2 opacity-0 group-hover:opacity-100 transition-opacity">
                <div class="w-2.5 h-2.5 border-t-2 border-l-2 border-white"></div>
              </div>
            </div>
          ))}
        </div>

        <!-- Category CTA -->
        <div class="mt-8 text-center">
          <a href="https://wa.me/573232218586?text=Hola%20Nebulab%203D%2C%20me%20interesan%20los%20{cat.label}"
             target="_blank" rel="noopener"
             class="inline-flex items-center gap-2 font-mono text-xs font-bold tracking-widest uppercase
                    text-neb-purple border-b border-dashed border-neb-purple/40
                    hover:border-neb-purple transition-colors pb-0.5">
            COTIZAR {cat.label.toUpperCase()}
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    ))}

  </div>

  <!-- ── Lightbox ── -->
  <div id="lightbox"
       class="fixed inset-0 z-[900] bg-neb-black/95 backdrop-blur-sm flex items-center justify-center p-4"
       style="display:none"
       onclick="closeLightbox(event)">
    <div class="relative max-w-3xl w-full">
      <button onclick="closeLightboxBtn()"
              class="absolute -top-10 right-0 font-mono text-white/60 hover:text-white text-sm tracking-widest transition-colors cursor-pointer">
        [ESC] CERRAR ✕
      </button>
      <div class="relative">
        <div class="absolute -top-1 -left-1 w-5 h-5 border-t-2 border-l-2 border-neb-purple"></div>
        <div class="absolute -bottom-1 -right-1 w-5 h-5 border-b-2 border-r-2 border-neb-blue"></div>
        <img id="lightbox-img" src="" alt="" class="w-full rounded-sm shadow-2xl" />
      </div>
      <p id="lightbox-caption" class="mt-3 text-center font-mono text-xs text-white/40 tracking-widest"></p>
    </div>
  </div>

</section>

<script>
  // ── Tab switching ───────────────────────────────────
  const tabs = document.querySelectorAll<HTMLButtonElement>('.gallery-tab');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const id = tab.dataset.tab!;
      // Update tabs
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      // Show/hide grids
      document.querySelectorAll('.gallery-grid').forEach(grid => {
        const el = grid as HTMLElement;
        el.style.display = el.id === `tab-${id}` ? 'block' : 'none';
      });
      // Re-trigger reveals for visible items
      document.querySelectorAll(`#tab-${id} .reveal`).forEach(el => {
        el.classList.remove('visible');
        setTimeout(() => el.classList.add('visible'), 50);
      });
    });
  });

  // ── Lightbox ───────────────────────────────────────
  const lb = document.getElementById('lightbox') as HTMLElement;
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbCap = document.getElementById('lightbox-caption') as HTMLElement;

  (window as any).openLightbox = (src: string, alt: string) => {
    lbImg.src = src;
    lbImg.alt = alt;
    lbCap.textContent = alt;
    lb.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  };
  (window as any).closeLightbox = (e: MouseEvent) => {
    if (e.target === lb) {
      lb.style.display = 'none';
      document.body.style.overflow = '';
    }
  };
  (window as any).closeLightboxBtn = () => {
    lb.style.display = 'none';
    document.body.style.overflow = '';
  };
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      lb.style.display = 'none';
      document.body.style.overflow = '';
    }
  });
</script>
