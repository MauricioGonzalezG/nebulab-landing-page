---
---
<footer class="border-t border-neb-purple/15 dark:border-neb-purple/20 py-12 px-6">
  <div class="max-w-7xl mx-auto">

    <!-- Top row -->
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8 mb-10">

      <!-- Logo + tagline -->
      <div class="flex flex-col gap-2">
        <div class="flex items-center gap-2.5">
          <img
            src="/images/logo/logo-principal.png"
            alt="Nebulab 3D"
            width="36"
            height="36"
            class="w-9 h-9 object-contain rounded-md ring-1 ring-neb-purple/40"
          />
          <span class="font-makoto font-black text-sm tracking-widest text-neb-ink dark:text-white">
            NEBULAB <span class="text-gradient">3D</span>
          </span>
        </div>
        <p class="font-mono text-[9px] tracking-[0.2em] uppercase text-neb-ink/35 dark:text-white/30 max-w-[240px]">
          Si lo puedes imaginar, lo podemos crear.
        </p>
      </div>

      <!-- Nav links -->
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap gap-6">
          {[
            ['#servicios', 'Servicios'],
            ['#galeria',   'Galería'],
            ['#nosotros',  'Nosotros'],
            ['#valores',   'Valores'],
            ['#contacto',  'Contacto'],
          ].map(([href, label]) => (
            <li>
              <a href={href}
                 class="font-mono text-[10px] tracking-[0.2em] uppercase
                        text-neb-ink/50 dark:text-white/40
                        hover:text-neb-purple dark:hover:text-neb-purple transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Social links -->
      <div class="flex items-center gap-3">
        <a href="https://wa.me/573232218586" target="_blank" rel="noopener" aria-label="WhatsApp"
           class="w-9 h-9 rounded-sm border border-neb-purple/25 dark:border-neb-purple/30
                  flex items-center justify-center
                  hover:bg-neb-purple/10 hover:border-neb-purple transition-all">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-neb-ink/60 dark:text-white/50" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </a>
        <a href="https://www.instagram.com/nebulab3d/" target="_blank" rel="noopener" aria-label="Instagram"
           class="w-9 h-9 rounded-sm border border-neb-purple/25 dark:border-neb-purple/30
                  flex items-center justify-center
                  hover:bg-neb-purple/10 hover:border-neb-purple transition-all">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
               class="text-neb-ink/60 dark:text-white/50" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Bottom strip -->
    <div class="border-t border-neb-purple/10 dark:border-neb-purple/15 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="font-mono text-[9px] tracking-[0.15em] uppercase text-neb-ink/30 dark:text-white/25">
        &copy; {new Date().getFullYear()} Nebulab 3D — Manizales &amp; Madrid, Cundinamarca
      </p>
      <div class="flex items-center gap-1.5">
        <div class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></div>
        <span class="font-mono text-[9px] tracking-[0.15em] uppercase text-neb-ink/30 dark:text-white/25">
          Impresoras activas
        </span>
      </div>
    </div>

  </div>
</footer>
